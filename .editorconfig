# EditorConfig — https://editorconfig.org
# Shared editor defaults for the SATEX monorepo. Line endings are governed by
# .gitattributes (LF in git objects; working-tree CRLF on Windows is expected).
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf
