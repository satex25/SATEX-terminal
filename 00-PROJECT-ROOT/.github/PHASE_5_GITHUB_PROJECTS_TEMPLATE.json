{
  "title": "PHASE 5: Code Hardening → Release",
  "description": "Automated tracking for SATEX Phase 5 (250 hours, 8 weeks)",
  "views": [
    {
      "name": "Timeline (Gantt)",
      "layout": "table",
      "fields": {
        "title": "Task",
        "assignees": "Owner",
        "status": "Status",
        "custom_start": "Start Date",
        "custom_end": "End Date",
        "custom_hours": "Hours"
      }
    },
    {
      "name": "Burndown",
      "layout": "table",
      "fields": {
        "title": "Category",
        "custom_total_hours": "Total Hours",
        "custom_completed_hours": "Completed",
        "custom_percent": "% Done",
        "custom_owner": "Owner"
      }
    },
    {
      "name": "By Status",
      "layout": "board",
      "grouping": "status",
      "statuses": [
        "TODO",
        "IN_PROGRESS",
        "BLOCKED",
        "DONE"
      ]
    },
    {
      "name": "By Category",
      "layout": "board",
      "grouping": "custom_category",
      "categories": [
        "A: Core Hardening",
        "B: Testing & QA",
        "C: Electron Packaging",
        "D: Integrations & Validation",
        "E: Documentation",
        "F: Release & Validation"
      ]
    },
    {
      "name": "Gates & Milestones",
      "layout": "table",
      "fields": {
        "title": "Gate",
        "milestone": "Milestone",
        "custom_target_date": "Target Date",
        "custom_criteria_count": "Criteria Met",
        "status": "Status"
      }
    }
  ],
  "automation": [
    {
      "trigger": "pull_request_merged",
      "action": "auto_close_related_issues",
      "description": "Auto-close issues mentioned in PR"
    },
    {
      "trigger": "daily",
      "action": "update_burndown",
      "description": "Daily burndown sync from PROGRESS_TRACKING.json"
    },
    {
      "trigger": "gate_date_reached",
      "action": "notify_assignees",
      "description": "Notify team when gate deadline approaches"
    }
  ],
  "issues_template": [
    {
      "id": "A1.1",
      "title": "Risk Invariant #1: No Negative Balances — Unit Tests",
      "category": "A: Core Hardening",
      "milestone": "Gate 1: Code Hardening (May 7)",
      "assignee": "Lead Engineer",
      "hours": 5,
      "dependencies": [],
      "labels": ["critical", "unit-test", "risk-engine"],
      "body": "Implement Vitest suite for OrderManager invariant: balances never go negative.\n\n**Acceptance Criteria:**\n- Test covers all entry/exit paths\n- 100% code coverage for balance checks\n- Test runs in < 200ms\n- All edge cases (rounding, margin, fees) covered\n\n**Files:** src/main/services/__tests__/order-manager.test.ts"
    },
    {
      "id": "A1.2",
      "title": "Risk Invariant #2: Max 5 Concurrent Orders — Unit Tests",
      "category": "A: Core Hardening",
      "milestone": "Gate 1: Code Hardening (May 7)",
      "assignee": "Lead Engineer",
      "hours": 5,
      "dependencies": ["A1.1"],
      "labels": ["critical", "unit-test", "risk-engine"]
    },
    {
      "id": "B1",
      "title": "Service Unit Tests: LearnedSL",
      "category": "B: Testing & QA",
      "milestone": "Gate 2: Testing (May 21)",
      "assignee": "QA Lead",
      "hours": 15,
      "dependencies": ["A1", "A2"],
      "labels": ["critical", "unit-test", "integration"]
    },
    {
      "id": "C1",
      "title": "electron-builder Config: Windows .exe Packaging",
      "category": "C: Electron Packaging",
      "milestone": "Gate 3: Packaging (May 28)",
      "assignee": "DevOps/Build Engineer",
      "hours": 20,
      "dependencies": ["B1", "B2", "B3"],
      "labels": ["critical", "packaging", "windows"]
    },
    {
      "id": "D1",
      "title": "ForexFactory Hardening: Error Handling & Circuit Breaker",
      "category": "D: Integrations & Validation",
      "milestone": "Gate 4: Integrations (Jun 11)",
      "assignee": "Integration Engineer",
      "hours": 25,
      "dependencies": ["C1", "C2", "C3"],
      "labels": ["critical", "integration", "robustness"]
    },
    {
      "id": "E1",
      "title": "CLAUDE.md Final Review: Docs Polish & Validation",
      "category": "E: Documentation",
      "milestone": "Gate 5: Documentation (Jun 18)",
      "assignee": "Tech Writer / Lead",
      "hours": 12,
      "dependencies": ["C1", "C2", "C3"],
      "labels": ["documentation"]
    },
    {
      "id": "F1",
      "title": "Pre-Release Validation: Full Checklist",
      "category": "F: Release & Validation",
      "milestone": "Gate 6: RELEASE (Jun 30)",
      "assignee": "Release Manager",
      "hours": 15,
      "dependencies": ["E1", "E2", "E3"],
      "labels": ["critical", "release"]
    }
  ],
  "custom_fields": [
    {
      "name": "custom_category",
      "type": "select",
      "options": ["A", "B", "C", "D", "E", "F"]
    },
    {
      "name": "custom_hours",
      "type": "number",
      "unit": "hours"
    },
    {
      "name": "custom_owner",
      "type": "text"
    },
    {
      "name": "custom_start",
      "type": "date"
    },
    {
      "name": "custom_end",
      "type": "date"
    },
    {
      "name": "custom_target_date",
      "type": "date"
    },
    {
      "name": "custom_criteria_count",
      "type": "number"
    }
  ],
  "milestones": [
    {
      "title": "Gate 1: Code Hardening",
      "date": "2026-05-07",
      "description": "Category A complete: Risk invariants & gates tested, profiling complete, IPC audited"
    },
    {
      "title": "Gate 2: Testing",
      "date": "2026-05-21",
      "description": "Category B complete: Service + integration tests, 80%+ coverage, manual QA sign-off"
    },
    {
      "title": "Gate 3: Packaging",
      "date": "2026-05-28",
      "description": "Category C complete: electron-builder config, CI/CD workflows, code signing"
    },
    {
      "title": "Gate 4: Integrations",
      "date": "2026-06-11",
      "description": "Category D complete: ForexFactory robust, Alpaca validated (paper + live gating), SQLite audited"
    },
    {
      "title": "Gate 5: Documentation",
      "date": "2026-06-18",
      "description": "Category E complete: CLAUDE.md polished, API docs, deployment runbook"
    },
    {
      "title": "Gate 6: RELEASE",
      "date": "2026-06-30",
      "description": "Category F complete: .exe built, signed, released on GitHub"
    }
  ]
}
