# ─────────────────────────────────────────────────────────────────────────────
# SATEX-CORE — hardened root .gitignore
# Mirror of satex-app/.gitignore at the repo root so nothing leaks into git
# from anywhere in the tree, plus defense-in-depth blocks for credential
# material and Electron userData artifacts.
# ─────────────────────────────────────────────────────────────────────────────

# Node / package managers
node_modules/
.npm/
.pnpm-store/
.yarn/

# Build outputs
out/
dist/
build/
.vite/
*.tsbuildinfo

# Test / coverage
coverage/
.nyc_output/
.vitest-cache/

# TypeScript incremental cache
*.tsbuildinfo

# Environment & secrets — keep templates, block everything else
.env.local
.env.*.local
.env.production
.env.development
*.local
# Allow the safe defaults and the public example
!.env
!.env.local.example
!.env.example

# Credentials material (defense in depth — these live in Electron userData,
# but explicitly block in case anyone ever dumps userData into the tree)
alpaca-creds.bin
anthropic-key.bin
*-creds.bin
*-key.bin
credentials.json
secrets.json
service-account.json

# SQLite & runtime data
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
userData/
app-data/

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Electron / packaging
release/
*.dmg
*.exe
*.msi
*.app
*.deb
*.rpm
*.AppImage
*.snap

# OS junk
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*.swn
.history/
*.code-workspace

# Temp / scratch
.tmp/
tmp/
.cache/
*.tmp
*.temp
.tmp_*

# Accidental Vite scaffold left over from `npm create vite -- --template react-ts`
# Real godmode app lives at satex-app/; this folder is unused boilerplate.
satex-app --template react-ts/
