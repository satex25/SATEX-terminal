# ================================================================
# SATEX — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ================================================================

# --- Alpaca Paper Trading (REQUIRED for live data / paper orders) ---
# Get credentials at: https://alpaca.markets → Paper → API Keys
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_FEED=iex

# --- Simulator mode (set to true to run without Alpaca) ---
# When true, the system uses a deterministic GBM price simulator.
# When false (default), the system connects to Alpaca paper account.
SATEX_USE_SIMULATOR=false

# --- Simulator PRNG seed (only used when SATEX_USE_SIMULATOR=true) ---
# Use a fixed integer for reproducible tick streams. Omit for random seed.
SATEX_RNG_SEED=

# --- Risk overrides (optional — see src/shared/constants.ts for defaults) ---
# SATEX_DAILY_LOSS_LIMIT_PCT=0.02
# SATEX_MAX_OPEN_POSITIONS=3
# SATEX_MAX_POSITION_CONCENTRATION=0.25

# --- Debug ---
# SATEX_LOG_LEVEL=info   # trace | debug | info | warn | error
