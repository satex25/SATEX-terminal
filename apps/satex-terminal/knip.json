{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/renderer/index.html",
    "src/renderer/main.tsx",
    "tests/e2e/**/*.spec.ts",
    "src/**/*.{test,spec}.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "!**/*.d.ts"
  ],
  "ignore": [
    "src/renderer/panels/FundedAccountPanel.tsx"
  ],
  "ignoreDependencies": [
    "playwright"
  ],
  "rules": {
    "files":         "error",
    "dependencies":  "error",
    "unresolved":    "error",
    "exports":       "warn",
    "types":         "warn",
    "duplicates":    "warn",
    "enumMembers":   "warn",
    "classMembers":  "warn",
    "nsExports":     "warn",
    "nsTypes":       "warn"
  }
}
