{
  "name": "satex-app",
  "version": "0.5.0",
  "private": true,
  "description": "SATEX — Smart Autonomous Trading EXperience. Institutional-grade autonomous trading terminal.",
  "author": "SATEX Engineering",
  "license": "MIT",
  "main": "out/main/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint:types": "npm run typecheck",
    "lint": "eslint src tests",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prepack:check": "node scripts/prepack-check.js",
    "backtest": "tsx scripts/backtest.ts",
    "pack:win": "npm run prepack:check && npm run build && electron-builder --win --x64 --publish never",
    "pack:dir": "npm run build && electron-builder --dir",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.9",
    "lightweight-charts": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "@tailwindcss/postcss": "^4.3.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.1.0",
    "vitest": "^4.1.10"
  }
}
